# LLM Provider
GEMINI_API_KEY=your_gemini_api_key_here

# Graph Database
MEMGRAPH_HOST=localhost
MEMGRAPH_PORT=7687

# Scraper Settings
SCRAPER_DELAY_MIN=1.0
SCRAPER_DELAY_MAX=3.0
SCRAPER_MAX_RETRIES=5
